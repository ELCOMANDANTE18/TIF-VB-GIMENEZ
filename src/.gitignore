# =============================================================
# .gitignore — Phishing Detector Instagram DMs
# =============================================================

# --- Entorno virtual ---
.venv/
venv/
env/
ENV/
.env/

# --- Variables de entorno y secrets ---
.env
.env.local
.env.production
.env.staging
# Permitir solo el ejemplo
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Distribución / build ---
build/
dist/
*.egg-info/
*.egg
.eggs/

# --- Testing y cobertura ---
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.log
nosetests.xml

# --- IDEs y editores ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs del sistema ---
*.log
logs/
log/

# --- Archivos temporales ---
*.tmp
*.temp
*.bak

# --- Ngrok ---
ngrok
ngrok.exe
.ngrok2/

# --- Datos sensibles del proyecto ---
data/tokens/
data/private/
# Permitir la blacklist pública
!data/blacklist.txt

# --- Jupyter Notebooks (checkpoints) ---
.ipynb_checkpoints/
*.ipynb

# --- Mypy / linters ---
.mypy_cache/
.ruff_cache/
.dmypy.json

# --- Docker ---
*.override.yml
docker-compose.override.yml

