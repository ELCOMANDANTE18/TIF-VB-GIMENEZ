# =============================================================
# .env.example — Link Seguro / Phishing Detector
# =============================================================

# ── Meta / Facebook App ───────────────────────────────────────
# ID de tu página de Facebook vinculada a la cuenta de Instagram
FACEBOOK_PAGE_ID=

# ID de tu app en Meta for Developers (developers.facebook.com)
META_APP_ID=

# Clave secreta de la app — Configuración → Información básica → Mostrar
# Se usa para validar la firma HMAC-SHA256 de cada evento del Webhook
META_APP_SECRET=

# ── Webhook ───────────────────────────────────────────────────
# Token que vos elegís — debe coincidir exactamente con el que
# registrás en Meta → Instagram → Configurar webhooks
META_VERIFY_TOKEN=

# ── Token principal de Instagram ──────────────────────────────
# Token de acceso de la cuenta que RECIBE los mensajes (flia_test)
# Se genera desde: api_tester → Instagram → Configuración de la API
# → Generar token al lado de la cuenta. Duración: ~60 días.
PAGE_ACCESS_TOKEN=

# ── Cuenta monitoreada (flia_test) ────────────────────────────
# Instagram User ID de la cuenta que recibe los DMs
# Se obtiene con: GET /me?fields=id con el token de esa cuenta
FLIA_TEST_IG_USER_ID=

# Token de acceso específico de flia_test
# Necesario para consultar el historial de conversaciones via API
FLIA_TEST_TOKEN=

# ── Motor de análisis ─────────────────────────────────────────
# Score mínimo para clasificar un mensaje como riesgo ALTO (0.0-1.0)
RISK_THRESHOLD_HIGH=0.7

# Score mínimo para clasificar un mensaje como riesgo MEDIO (0.0-1.0)
RISK_THRESHOLD_MEDIUM=0.4

# Peso del análisis de URLs en el score final (debe sumar 1.0 con TEXT_WEIGHT)
URL_WEIGHT=0.6

# Peso del análisis de texto en el score final
TEXT_WEIGHT=0.4

